/** @file license.h.in
 *  @brief CMake template for license.h. @NOESIS_LICENSE_NAME@ and @NOESIS_LICENSE_KEY@
 *         are substituted at configure time from the matching -D CMake variables so the
 *         license doesn't end up in git history.
 */
#pragma once
// DO NOT ADD YOUR LICENSE MANUALLY IN THIS FILE
// READ THE DOCUMENTATION ON HOW TO CONFIGURE CMAKE

// Noesis license information
// A trial license for development purposes can be acquired free of charge at https://www.noesisengine.com/trial/
static const char licenseName[] = "@NOESIS_LICENSE_NAME@";
static const char licenseKey[]  = "@NOESIS_LICENSE_KEY@";

static_assert( sizeof( licenseName ) > 1 && sizeof( licenseKey ) > 1, "Please provide a working Noesis license or Noesis will stop working after a few minutes" );
