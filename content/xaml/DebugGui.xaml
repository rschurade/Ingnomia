<UserControl
	x:Class="IngnomiaGUI.DebugGui"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="clr-namespace:IngnomiaGUI"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity" xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
	x:Name="DebugControl">
	<UserControl.DataContext>
		<local:DebugModel />
	</UserControl.DataContext>
	<UserControl.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="styles/mainmenu/styles.xaml" />
				<ResourceDictionary Source="localization/en_US.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</UserControl.Resources>

	<Grid x:Name="LayoutRoot">
		<StackPanel Orientation="Horizontal">
			<Border x:Name="TabBorder1" Style="{StaticResource Panel}" MinWidth="100" Margin="2">
				<StackPanel>
					<Button Style="{StaticResource SquareButton}"
						Command="{Binding PageCmd}"
						CommandParameter="Gnomes">
						<StackPanel>
							<Image Source="buttons/skills.png" Stretch="None" />
							<TextBlock Text="Gnomes"></TextBlock>
						</StackPanel>
					</Button>
					<Button Style="{StaticResource SquareButton}"
						Command="{Binding PageCmd}"
						CommandParameter="Items">
						<StackPanel>
							<Image Source="buttons/schedule.png" Stretch="None" />
							<TextBlock Text="Items"></TextBlock>
						</StackPanel>
					</Button>
					<Button Style="{StaticResource SquareButton}"
						Command="{Binding PageCmd}"
						CommandParameter="Game">
						<StackPanel>
							<Image Source="buttons/professions.png" Stretch="None" />
							<TextBlock Text="Game"></TextBlock>
						</StackPanel>
					</Button>
				</StackPanel>
			</Border>

			<Border x:Name="TabBorder2" Style="{StaticResource Panel}" MinWidth="800" MaxWidth="800" Margin="2">
				<Grid>
					<!-- Page 1: Gnome Controls -->
					<Grid x:Name="LayoutGnomes" Visibility="{Binding ShowGnomes}">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="1*" />
						</Grid.RowDefinitions>

						<TextBlock Text="Gnome Controls" FontSize="20" Grid.Row="0" Margin="4" />

						<!-- Gnome selector -->
						<StackPanel Orientation="Horizontal" Grid.Row="1" Margin="4">
							<TextBlock Text="Gnome:" VerticalAlignment="Center" Width="80" />
							<ComboBox Width="200"
								ItemsSource="{Binding GnomeList}"
								SelectedItem="{Binding SelectedGnome, Mode=TwoWay}"
								ItemTemplate="{StaticResource ItemTemplate}" />
						</StackPanel>

						<!-- Hunger -->
						<StackPanel Orientation="Horizontal" Grid.Row="2" Margin="4">
							<TextBlock Text="Hunger:" VerticalAlignment="Center" Width="80" />
							<Slider Width="200" Minimum="-100" Maximum="100"
								Value="{Binding HungerValue, Mode=TwoWay}" SmallChange="1" LargeChange="10" />
							<TextBlock Text="{Binding HungerText}" VerticalAlignment="Center" Width="40" Margin="4,0" />
							<Button Content="Set" Command="{Binding SetHungerCmd}" Width="50" />
						</StackPanel>

						<!-- Thirst -->
						<StackPanel Orientation="Horizontal" Grid.Row="3" Margin="4">
							<TextBlock Text="Thirst:" VerticalAlignment="Center" Width="80" />
							<Slider Width="200" Minimum="-100" Maximum="100"
								Value="{Binding ThirstValue, Mode=TwoWay}" SmallChange="1" LargeChange="10" />
							<TextBlock Text="{Binding ThirstText}" VerticalAlignment="Center" Width="40" Margin="4,0" />
							<Button Content="Set" Command="{Binding SetThirstCmd}" Width="50" />
						</StackPanel>

						<!-- Sleep -->
						<StackPanel Orientation="Horizontal" Grid.Row="4" Margin="4">
							<TextBlock Text="Sleep:" VerticalAlignment="Center" Width="80" />
							<Slider Width="200" Minimum="-100" Maximum="100"
								Value="{Binding SleepValue, Mode=TwoWay}" SmallChange="1" LargeChange="10" />
							<TextBlock Text="{Binding SleepText}" VerticalAlignment="Center" Width="40" Margin="4,0" />
							<Button Content="Set" Command="{Binding SetSleepCmd}" Width="50" />
						</StackPanel>

						<!-- Actions -->
						<StackPanel Orientation="Horizontal" Grid.Row="5" Margin="4">
							<Button Content="Kill Gnome" Command="{Binding KillGnomeCmd}" Width="100" Margin="0,0,8,0" />
							<Button Content="Spawn Gnome" Command="{Binding SpawnCmd}" CommandParameter="Gnome" Width="100" Margin="0,0,8,0" />
							<Button Content="Spawn Trader" Command="{Binding SpawnCmd}" CommandParameter="Trader" Width="100" Margin="0,0,8,0" />
							<Button Content="Spawn Goblin" Command="{Binding SpawnCmd}" CommandParameter="Goblin" Width="100" />
						</StackPanel>

						<!-- Window size -->
						<StackPanel Orientation="Horizontal" Grid.Row="6" Margin="4">
							<TextBlock Text="Window:" VerticalAlignment="Center" Width="80" />
							<ComboBox Width="200"
								ItemsSource="{Binding WindowSizes}"
								SelectedItem="{Binding SelectedWindowSize, Mode=TwoWay}"
								ItemTemplate="{StaticResource ItemTemplate}" />
						</StackPanel>
					</Grid>

					<!-- Page 2: Item Controls -->
					<Grid x:Name="LayoutItems" Visibility="{Binding ShowItems}">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="1*" />
						</Grid.RowDefinitions>

						<TextBlock Text="Item Controls" FontSize="20" Grid.Row="0" Margin="4" />

						<StackPanel Orientation="Horizontal" Grid.Row="1" Margin="4">
							<TextBlock Text="Group:" VerticalAlignment="Center" Width="80" />
							<ComboBox Width="200"
								ItemsSource="{Binding ItemGroupList}"
								SelectedItem="{Binding SelectedItemGroup, Mode=TwoWay}"
								ItemTemplate="{StaticResource ItemTemplate}" />
						</StackPanel>

						<StackPanel Orientation="Horizontal" Grid.Row="2" Margin="4">
							<TextBlock Text="Item:" VerticalAlignment="Center" Width="80" />
							<ComboBox Width="200"
								ItemsSource="{Binding ItemList}"
								SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
								ItemTemplate="{StaticResource ItemTemplate}" />
						</StackPanel>

						<StackPanel Orientation="Horizontal" Grid.Row="3" Margin="4">
							<TextBlock Text="Material 1:" VerticalAlignment="Center" Width="80" />
							<ComboBox Width="200"
								ItemsSource="{Binding Material1List}"
								SelectedItem="{Binding SelectedMaterial1, Mode=TwoWay}"
								ItemTemplate="{StaticResource ItemTemplate}" />
						</StackPanel>

						<StackPanel Orientation="Horizontal" Grid.Row="4" Margin="4"
							Visibility="{Binding ShowMaterial2}">
							<TextBlock Text="Material 2:" VerticalAlignment="Center" Width="80" />
							<ComboBox Width="200"
								ItemsSource="{Binding Material2List}"
								SelectedItem="{Binding SelectedMaterial2, Mode=TwoWay}"
								ItemTemplate="{StaticResource ItemTemplate}" />
						</StackPanel>

						<StackPanel Orientation="Horizontal" Grid.Row="5" Margin="4">
							<TextBlock Text="Count:" VerticalAlignment="Center" Width="80" />
							<TextBox Text="{Binding SpawnCount, Mode=TwoWay}" Width="60" />
							<TextBlock Text="  X:" VerticalAlignment="Center" Width="30" />
							<TextBox Text="{Binding SpawnX, Mode=TwoWay}" Width="50" />
							<TextBlock Text="  Y:" VerticalAlignment="Center" Width="30" />
							<TextBox Text="{Binding SpawnY, Mode=TwoWay}" Width="50" />
							<TextBlock Text="  Z:" VerticalAlignment="Center" Width="30" />
							<TextBox Text="{Binding SpawnZ, Mode=TwoWay}" Width="50" />
						</StackPanel>

						<StackPanel Orientation="Horizontal" Grid.Row="6" Margin="4">
							<Button Content="Spawn Items" Command="{Binding SpawnItemCmd}" Width="120" />
						</StackPanel>
					</Grid>

					<!-- Page 3: Game Controls -->
					<Grid x:Name="LayoutGame" Visibility="{Binding ShowGame}">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="1*" />
						</Grid.RowDefinitions>

						<TextBlock Text="Game Controls" FontSize="20" Grid.Row="0" Margin="4" />

						<StackPanel Orientation="Horizontal" Grid.Row="1" Margin="4">
							<TextBlock Text="Need Decay:" VerticalAlignment="Center" Width="100" />
							<Slider Width="200" Minimum="0" Maximum="10"
								Value="{Binding NeedDecayMultiplier, Mode=TwoWay}" />
							<TextBlock Text="{Binding NeedDecayText}" VerticalAlignment="Center" Width="40" Margin="4,0" />
							<TextBlock Text="x" VerticalAlignment="Center" />
						</StackPanel>

						<StackPanel Orientation="Horizontal" Grid.Row="2" Margin="4">
							<CheckBox Content="Disable Sleep Decay" IsChecked="{Binding DisableSleepDecay, Mode=TwoWay}" Margin="0,0,16,0" />
							<CheckBox Content="Disable Hunger Decay" IsChecked="{Binding DisableHungerDecay, Mode=TwoWay}" Margin="0,0,16,0" />
							<CheckBox Content="Disable Thirst Decay" IsChecked="{Binding DisableThirstDecay, Mode=TwoWay}" />
						</StackPanel>
					</Grid>
				</Grid>
			</Border>
			<Button Content="X" MaxHeight="32" Margin="2" VerticalAlignment="Top"
				Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:GameGui}}, Path=DataContext.CloseWindowCmd }"
				CommandParameter="DebugWindow" />
		</StackPanel>
	</Grid>
</UserControl>
